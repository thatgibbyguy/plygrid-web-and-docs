---
import "../index.scss";
import Search from "../components/Search";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const sections = [
  { label: "Getting Started", items: [
    { path: "/docs/installation", label: "Installation" },
    { path: "/docs/semantic-html", label: "Semantic HTML" },
    { path: "/docs/ai-agents", label: "AI Agents" },
  ]},
  { label: "Design", items: [
    { path: "/docs/colors", label: "Colors & Theming" },
    { path: "/docs/typography", label: "Typography" },
  ]},
  { label: "Layout", items: [
    { path: "/docs/grid", label: "Grid" },
  ]},
  { label: "Components", items: [
    { path: "/docs/buttons", label: "Buttons" },
    { path: "/docs/forms", label: "Forms" },
    { path: "/docs/navigation", label: "Navigation" },
    { path: "/docs/tables", label: "Tables" },
    { path: "/docs/alerts", label: "Alerts" },
  ]},
  { label: "Helpers", items: [
    { path: "/docs/utilities", label: "Utilities" },
    { path: "/docs/accessibility", label: "Accessibility" },
  ]},
  { label: "Compliance", items: [
    { path: "/docs/compliance", label: "Title II & WCAG" },
    { path: "/docs/vpat", label: "VPAT 2.5" },
  ]},
];

const flatLinks = sections.flatMap((s) => s.items);

const isHome = currentPath === "/";
const isGettingStarted = ["/docs/installation", "/docs/semantic-html", "/docs/ai-agents", "/docs/colors", "/docs/typography", "/docs/grid"].includes(currentPath);
const isComponents = ["/docs/buttons", "/docs/forms", "/docs/navigation", "/docs/tables", "/docs/alerts"].includes(currentPath);
const isHelpers = ["/docs/utilities", "/docs/accessibility"].includes(currentPath);
const isCompliance = ["/docs/compliance"].includes(currentPath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="navigation-fixed width-100">
      <nav class="navbar navbar-borderless hide-on-mobile" aria-label="Main">
        <ul class="items-center">
          <li class={isHome ? "active" : ""}>
            <a href="/" aria-label="Home">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </a>
          </li>
          <li class={isGettingStarted ? "active" : ""}>
            <a href="/docs/installation">Docs</a>
          </li>
          <li class={isComponents ? "active" : ""}>
            <a href="/docs/buttons">Components</a>
          </li>
          <li class={isHelpers ? "active" : ""}>
            <a href="/docs/utilities">Helpers</a>
          </li>
          <li class={isCompliance ? "active" : ""}>
            <a href="/docs/compliance">Compliance</a>
          </li>
          <li class="margin-left-auto display-flex gap-sm items-center">
            <Search client:load />
            <button
              class="btn btn-ghost btn-icon"
              id="theme-toggle"
              aria-label="Toggle theme"
              title="Toggle theme"
            >
              <svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              <svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
          </li>
        </ul>
      </nav>
      <nav class="navbar navbar-borderless hide-on-desktop" aria-label="Main">
        <ul>
          <li>
            <button
              class="navigation-toggle display-inline-block"
              id="mobile-nav-toggle"
              aria-expanded="false"
              aria-controls="mobile-nav"
              aria-label="Toggle navigation"
            >
              <span>Menu</span>
            </button>
          </li>
          <li class="margin-left-auto display-flex gap-sm items-center">
            <Search client:load />
            <button
              class="btn btn-ghost btn-icon"
              id="theme-toggle-mobile"
              aria-label="Toggle theme"
              title="Toggle theme"
            >
              <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
          </li>
        </ul>
        <nav class="nav-stacked" id="mobile-nav" aria-label="Documentation menu" style="display:none">
          <ul>
            {flatLinks.map((link) => (
              <li class={currentPath === link.path ? "active" : ""}>
                <a href={link.path}>{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </nav>
    </header>

    <div class="padding-top-extra margin-top-extra">
      {isHome ? (
        <main id="main">
          <slot />
        </main>
      ) : (
        <div class="doc-layout">
          <aside class="doc-sidebar hide-on-mobile" aria-label="Documentation navigation">
            <nav class="doc-sidebar-inner no-link-style" aria-label="Documentation">
              {sections.map((section) => (
                <div class="bottom-margin">
                  <p class="text-xs font-semibold uppercase text-tertiary no-margin padding-left padding-bottom" style="padding-left: 0.75rem" role="presentation">
                    {section.label}
                  </p>
                  <ul class="flat-list">
                    {section.items.map((item) => (
                      <li>
                        <a
                          href={item.path}
                          class={`doc-sidebar-link display-block text-sm ${currentPath === item.path ? "font-semibold doc-sidebar-link-active" : "text-secondary"}`}
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>
          </aside>
          <main id="main" class="doc-content">
            <slot />
          </main>
          <aside class="doc-toc hide-on-mobile" aria-label="Table of contents">
            <slot name="toc" />
          </aside>
        </div>
      )}
    </div>

    <footer class="padding-top padding-bottom text-sm text-muted" aria-label="Site footer">
      <div class="units-container">
        <p class="text-center no-margin">
          <strong>ply</strong> · MIT License ·
          <a href="https://github.com/thatgibbyguy/ply" target="_blank" rel="noopener noreferrer">GitHub</a>
          {" · "}
          <a href="https://www.npmjs.com/package/plygrid" target="_blank" rel="noopener noreferrer">npm</a>
        </p>
      </div>
    </footer>

    <script>
      // Theme toggle
      function getTheme() {
        const stored = document.documentElement.getAttribute("data-theme");
        if (stored === "light" || stored === "dark") return stored;
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      }

      function applyTheme(theme: string) {
        document.documentElement.setAttribute("data-theme", theme);
        // Update all sun/moon icons
        document.querySelectorAll("#theme-icon-sun, .theme-icon-sun").forEach(el => {
          (el as HTMLElement).style.display = theme === "light" ? "" : "none";
        });
        document.querySelectorAll("#theme-icon-moon, .theme-icon-moon").forEach(el => {
          (el as HTMLElement).style.display = theme === "dark" ? "" : "none";
        });
      }

      function toggleTheme() {
        const current = getTheme();
        const next = current === "dark" ? "light" : "dark";
        applyTheme(next);
      }

      // Init theme
      applyTheme(getTheme());

      // Bind toggle buttons
      document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
      document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

      // Mobile nav toggle
      const mobileToggle = document.getElementById("mobile-nav-toggle");
      const mobileNav = document.getElementById("mobile-nav");
      mobileToggle?.addEventListener("click", () => {
        const isOpen = mobileNav?.style.display !== "none";
        if (mobileNav) mobileNav.style.display = isOpen ? "none" : "";
        mobileToggle.setAttribute("aria-expanded", String(!isOpen));
        mobileToggle.classList.toggle("navigation-toggle-show", !isOpen);
      });
    </script>
  </body>
</html>
