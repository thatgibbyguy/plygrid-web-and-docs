---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found — ply">
  <div class="units-container padding-top-extra padding-bottom-extra">
    <div class="units-row centered-content">
      <div class="unit-50 phone-unit-100 text-center">
        <h1>
          <span class="text-5xl font-bold display-block bottom-margin">404</span>
          Page Not Found
        </h1>
        <p class="bottom-margin-extra">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <a href="/" class="btn btn-blue">Back to Home</a>
      </div>
    </div>
  </div>
</Layout>
