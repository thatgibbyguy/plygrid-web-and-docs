                  layer-{n}
                </div>
              </div>
            ))}
          </div>
          <div class="units-row">
            {[1, 2, 3].map((n) => (
              <div class="unit-33 phone-unit-100 bottom-margin">
                <div class={`shadow-${n} padding text-center border-radius`}>
