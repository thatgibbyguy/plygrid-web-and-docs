---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<DocsLayout title="Table Interaction" description="Sort indicators, filter bars, pagination controls, and action toolbars for interactive data tables in ply.">
  <section class="padding-top-extra padding-bottom-extra border-bottom">
    <p class="text-xs font-semibold uppercase color-blue">Components</p>
    <h1 class="text-balance">Table Interaction</h1>
    <p class="lead no-orphan">
      Sort indicators, pagination controls, and filter wrappers for interactive
      data tables. Pure CSS — add classes and let your JS handle the logic.
    </p>
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="sort-indicators">
    <p class="text-xs font-semibold uppercase color-blue">Sorting</p>
    <h2>Sort Indicators</h2>
    <p class="no-orphan">
      Add <code>sortable</code> to <code>&lt;th&gt;</code> elements to show sort arrows.
      Toggle <code>sort-asc</code> or <code>sort-desc</code> to indicate the active sort direction.
    </p>

    <div class="border border-radius padding">
      <table class="table-stroked">
        <thead>
          <tr>
            <th class="sortable sort-asc">Name</th>
            <th class="sortable">Email</th>
            <th class="sortable sort-desc">Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Alice Williams</td><td>alice@example.com</td><td>Editor</td><td>Active</td></tr>
          <tr><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td><td>Inactive</td></tr>
          <tr><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td><td>Active</td></tr>
        </tbody>
      </table>
    </div>

    <CodeBlock code={`<table class="table-stroked">
  <thead>
    <tr>
      <th class="sortable sort-asc">Name</th>
      <th class="sortable">Email</th>
      <th class="sortable sort-desc">Role</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>...</tbody>
</table>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="table-filter">
    <p class="text-xs font-semibold uppercase color-blue">Filtering</p>
    <h2>Table Filter</h2>
    <p class="no-orphan">
      Add <code>table-filter</code> alongside <code>input-groups</code> to
      build a connected filter bar. The select auto-sizes to its content
      while the search input fills the remaining space.
    </p>

    <div class="border border-radius padding">
      <div class="input-groups table-filter">
        <input type="text" placeholder="Search users..." aria-label="Search users" />
        <select aria-label="Filter by role">
          <option value="">All Roles</option>
          <option>Admin</option>
          <option>Editor</option>
          <option>Viewer</option>
        </select>
        <span class="btn-append">
          <button class="btn btn-blue">Filter</button>
        </span>
      </div>
      <table class="table-stroked table-hovered">
        <thead>
          <tr>
            <th class="sortable">Name</th>
            <th class="sortable">Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td><td><span class="success">Active</span></td></tr>
          <tr><td>John Smith</td><td>john@example.com</td><td>Editor</td><td><span class="success">Active</span></td></tr>
          <tr><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td><td><span class="error">Inactive</span></td></tr>
        </tbody>
      </table>
    </div>

    <CodeBlock code={`<div class="input-groups table-filter">
  <input type="text" placeholder="Search..." aria-label="Search">
  <select aria-label="Filter by role">
    <option value="">All Roles</option>
    <option>Admin</option>
  </select>
  <span class="btn-append">
    <button class="btn btn-blue">Filter</button>
  </span>
</div>
<table class="table-stroked table-hovered">...</table>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="table-actions">
    <p class="text-xs font-semibold uppercase color-blue">Actions</p>
    <h2>Table Actions</h2>
    <p class="no-orphan">
      Use <code>table-actions</code> for right-aligned icon buttons above a table.
      Pair with <code>btn-ghost btn-icon</code> for a clean toolbar look.
    </p>

    <div class="border border-radius padding">
      <div class="table-actions">
        <button class="btn btn-ghost btn-icon" aria-label="Download" title="Download">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
        <button class="btn btn-ghost btn-icon" aria-label="Print" title="Print">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        </button>
        <button class="btn btn-ghost btn-icon" aria-label="Delete selected" title="Delete selected">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
        </button>
      </div>
      <table class="table-stroked">
        <thead>
          <tr>
            <th style="width: 2rem"><input type="checkbox" aria-label="Select all" /></th>
            <th class="sortable">Name</th>
            <th class="sortable">Email</th>
            <th>Role</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><input type="checkbox" aria-label="Select row" /></td><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td></tr>
          <tr><td><input type="checkbox" aria-label="Select row" /></td><td>John Smith</td><td>john@example.com</td><td>Editor</td></tr>
          <tr><td><input type="checkbox" aria-label="Select row" /></td><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td></tr>
        </tbody>
      </table>
    </div>

    <CodeBlock code={`<div class="table-actions">
  <button class="btn btn-ghost btn-icon" aria-label="Download">...</button>
  <button class="btn btn-ghost btn-icon" aria-label="Print">...</button>
  <button class="btn btn-ghost btn-icon" aria-label="Delete">...</button>
</div>
<table class="table-stroked">...</table>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="pagination">
    <p class="text-xs font-semibold uppercase color-blue">Navigation</p>
    <h2>Table with Pagination</h2>
    <p class="no-orphan">
      ply already provides <code>.pagination</code> in its navigation module.
      Place it below the table with a <code>pagination-info</code> label for context.
    </p>

    <div class="border border-radius padding">
      <table class="table-stroked table-hovered">
        <thead>
          <tr>
            <th class="sortable sort-asc">Name</th>
            <th class="sortable">Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td><td><span class="success">Active</span></td></tr>
          <tr><td>John Smith</td><td>john@example.com</td><td>Editor</td><td><span class="success">Active</span></td></tr>
          <tr><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td><td><span class="error">Inactive</span></td></tr>
        </tbody>
      </table>
      <div class="display-flex items-center justify-between flex-wrap gap margin-top">
        <span class="pagination-info">Showing 1–3 of 48</span>
        <nav aria-label="Table pagination">
          <ul class="pagination">
            <li class="disabled"><span aria-disabled="true">&laquo;</span></li>
            <li class="active"><a href="#pagination" aria-current="page">1</a></li>
            <li><a href="#pagination">2</a></li>
            <li><a href="#pagination">3</a></li>
            <li><a href="#pagination">...</a></li>
            <li><a href="#pagination">16</a></li>
            <li><a href="#pagination">&raquo;</a></li>
          </ul>
        </nav>
      </div>
    </div>

    <CodeBlock code={`<table class="table-stroked table-hovered">
  <!-- table content -->
</table>
<div class="display-flex items-center justify-between margin-top">
  <span class="pagination-info">Showing 1–3 of 48</span>
  <nav aria-label="Table pagination">
    <ul class="pagination">
      <li><span>&laquo;</span></li>
      <li class="active"><a href="#" aria-current="page">1</a></li>
      <li><a href="#">2</a></li>
      <li><a href="#">3</a></li>
      <li><a href="#">&raquo;</a></li>
    </ul>
  </nav>
</div>`} />

    <h3>Solid Variant</h3>
    <p class="no-orphan">
      Add <code>pagination-solid</code> for a filled style with no borders — hover and active states use a solid background.
    </p>

    <div class="border border-radius padding">
      <nav aria-label="Solid pagination">
        <ul class="pagination pagination-solid">
          <li><a href="#pagination">&laquo;</a></li>
          <li class="active"><a href="#pagination" aria-current="page">1</a></li>
          <li><a href="#pagination">2</a></li>
          <li><a href="#pagination">3</a></li>
          <li><a href="#pagination">...</a></li>
          <li><a href="#pagination">16</a></li>
          <li><a href="#pagination">&raquo;</a></li>
        </ul>
      </nav>
    </div>

    <CodeBlock code={`<!-- Outlined (default) -->
<ul class="pagination">...</ul>

<!-- Solid — filled hover/active, no borders -->
<ul class="pagination pagination-solid">...</ul>`} />

    <h3>Pagination Sizes</h3>
    <p class="no-orphan">
      Add <code>pagination-sm</code> or <code>pagination-lg</code> for compact or spacious variants.
      Sizes work with both outlined and solid styles.
    </p>

    <div class="border border-radius padding">
      <p class="text-xs font-semibold uppercase text-secondary">Small</p>
      <nav aria-label="Small pagination">
        <ul class="pagination pagination-sm">
          <li><a href="#pagination">&laquo;</a></li>
          <li class="active"><a href="#pagination" aria-current="page">1</a></li>
          <li><a href="#pagination">2</a></li>
          <li><a href="#pagination">3</a></li>
          <li><a href="#pagination">&raquo;</a></li>
        </ul>
      </nav>

      <p class="text-xs font-semibold uppercase text-secondary margin-top-extra">Default</p>
      <nav aria-label="Default pagination">
        <ul class="pagination">
          <li><a href="#pagination">&laquo;</a></li>
          <li class="active"><a href="#pagination" aria-current="page">1</a></li>
          <li><a href="#pagination">2</a></li>
          <li><a href="#pagination">3</a></li>
          <li><a href="#pagination">&raquo;</a></li>
        </ul>
      </nav>

      <p class="text-xs font-semibold uppercase text-secondary margin-top-extra">Large</p>
      <nav aria-label="Large pagination">
        <ul class="pagination pagination-lg">
          <li><a href="#pagination">&laquo;</a></li>
          <li class="active"><a href="#pagination" aria-current="page">1</a></li>
          <li><a href="#pagination">2</a></li>
          <li><a href="#pagination">3</a></li>
          <li><a href="#pagination">&raquo;</a></li>
        </ul>
      </nav>
    </div>

    <CodeBlock code={`<ul class="pagination pagination-sm">...</ul>
<ul class="pagination">...</ul>
<ul class="pagination pagination-lg">...</ul>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra" id="reference">
    <p class="text-xs font-semibold uppercase color-blue">Reference</p>
    <h2>Class Reference</h2>

    <table class="table-stroked">
      <thead>
        <tr><th>Class</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>sortable</code></td><td>Makes a <code>&lt;th&gt;</code> show sort arrows and hover state</td></tr>
        <tr><td><code>sort-asc</code></td><td>Highlights ascending arrow on a <code>sortable</code> header</td></tr>
        <tr><td><code>sort-desc</code></td><td>Highlights descending arrow on a <code>sortable</code> header</td></tr>
        <tr><td><code>table-filter</code></td><td>Add to <code>input-groups</code> — auto-sizes selects to content width</td></tr>
        <tr><td><code>table-actions</code></td><td>Right-aligned icon button toolbar above a table</td></tr>
        <tr><td><code>pagination</code></td><td>Outlined page navigation with rounded corners (default)</td></tr>
        <tr><td><code>pagination-solid</code></td><td>Solid/filled variant — no borders, filled hover and active</td></tr>
        <tr><td><code>pagination-sm</code></td><td>Compact pagination (smaller padding and font)</td></tr>
        <tr><td><code>pagination-lg</code></td><td>Spacious pagination (larger padding and font)</td></tr>
        <tr><td><code>pagination-info</code></td><td>Summary text beside pagination ("Showing 1–10 of 48")</td></tr>
      </tbody>
    </table>
  </section>
</DocsLayout>
