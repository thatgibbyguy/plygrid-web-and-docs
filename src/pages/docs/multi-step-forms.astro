---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<DocsLayout title="Multi-Step Forms" description="Step indicators, progress states, and wizard layouts for multi-step forms. Horizontal, vertical, and small variants.">
  <section class="padding-top-extra padding-bottom-extra border-bottom">
    <p class="text-xs font-semibold uppercase color-blue">Components</p>
    <h1 class="text-balance">Multi-Step Forms</h1>
    <p class="lead no-orphan">
      Step indicators, progress states, and form panel layouts for wizards
      and multi-step workflows. Pure CSS step styling — wire up the logic
      in your JS framework.
    </p>
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="horizontal-steps">
    <p class="text-xs font-semibold uppercase color-blue">Layout</p>
    <h2>Horizontal Steps</h2>
    <p class="no-orphan">
      Use <code>&lt;ol class="steps"&gt;</code> with <code>&lt;li class="step"&gt;</code> children.
      Mark the current step with <code>active</code> and previous steps with <code>completed</code>.
    </p>

    <div class="border border-radius padding padding-top-extra">
      <ol class="steps">
        <li class="step completed">
          <span class="step-label">Account</span>
        </li>
        <li class="step completed">
          <span class="step-label">Profile</span>
        </li>
        <li class="step active">
          <span class="step-label">Payment</span>
        </li>
        <li class="step">
          <span class="step-label">Confirm</span>
        </li>
      </ol>
    </div>

    <CodeBlock code={`<ol class="steps">
  <li class="step completed"><span class="step-label">Account</span></li>
  <li class="step completed"><span class="step-label">Profile</span></li>
  <li class="step active"><span class="step-label">Payment</span></li>
  <li class="step"><span class="step-label">Confirm</span></li>
</ol>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="step-states">
    <p class="text-xs font-semibold uppercase color-blue">States</p>
    <h2>Step States</h2>
    <p class="no-orphan">
      Steps support four states: default (upcoming), <code>active</code> (current),
      <code>completed</code> (done, shows checkmark), and <code>step-error</code> (needs attention).
    </p>

    <div class="border border-radius padding padding-top-extra">
      <ol class="steps">
        <li class="step completed">
          <span class="step-label">Details</span>
        </li>
        <li class="step step-error">
          <span class="step-label">Verification</span>
        </li>
        <li class="step active">
          <span class="step-label">Review</span>
        </li>
        <li class="step">
          <span class="step-label">Submit</span>
        </li>
      </ol>
    </div>

    <CodeBlock code={`<li class="step completed">...</li>  <!-- Checkmark -->
<li class="step step-error">...</li>  <!-- Error exclamation -->
<li class="step active">...</li>       <!-- Current step (blue) -->
<li class="step">...</li>              <!-- Upcoming (gray) -->`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="with-descriptions">
    <p class="text-xs font-semibold uppercase color-blue">Detailed</p>
    <h2>Steps with Descriptions</h2>

    <div class="border border-radius padding padding-top-extra">
      <ol class="steps">
        <li class="step completed">
          <span class="step-label">Account</span>
          <span class="step-desc">Email &amp; password</span>
        </li>
        <li class="step active">
          <span class="step-label">Profile</span>
          <span class="step-desc">Name &amp; avatar</span>
        </li>
        <li class="step">
          <span class="step-label">Preferences</span>
          <span class="step-desc">Notifications</span>
        </li>
      </ol>
    </div>

    <CodeBlock code={`<li class="step active">
  <span class="step-label">Profile</span>
  <span class="step-desc">Name & avatar</span>
</li>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="small-steps">
    <p class="text-xs font-semibold uppercase color-blue">Size</p>
    <h2>Small Steps</h2>

    <div class="border border-radius padding padding-top-extra">
      <ol class="steps steps-sm">
        <li class="step completed"><span class="step-label">1</span></li>
        <li class="step completed"><span class="step-label">2</span></li>
        <li class="step active"><span class="step-label">3</span></li>
        <li class="step"><span class="step-label">4</span></li>
        <li class="step"><span class="step-label">5</span></li>
      </ol>
    </div>

    <CodeBlock code={`<ol class="steps steps-sm">
  <li class="step completed">...</li>
  <li class="step active">...</li>
  <li class="step">...</li>
</ol>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="vertical-steps">
    <p class="text-xs font-semibold uppercase color-blue">Vertical</p>
    <h2>Vertical Steps</h2>
    <p class="no-orphan">
      Add <code>steps-vertical</code> to the <code>steps</code> container for a
      vertical layout. Use <code>step-content</code> for label and description beside the circle.
    </p>

    <div class="border border-radius padding padding-top-extra">
      <div class="units-row">
        <div class="unit-50 phone-unit-100">
          <ol class="steps steps-vertical">
            <li class="step completed">
              <div class="step-content">
                <span class="step-label">Create account</span>
                <span class="step-desc">Set up your email and password</span>
              </div>
            </li>
            <li class="step active">
              <div class="step-content">
                <span class="step-label">Add team members</span>
                <span class="step-desc">Invite colleagues to your workspace</span>
              </div>
            </li>
            <li class="step">
              <div class="step-content">
                <span class="step-label">Configure integrations</span>
                <span class="step-desc">Connect your tools</span>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>

    <CodeBlock code={`<ol class="steps steps-vertical">
  <li class="step completed">
    <div class="step-content">
      <span class="step-label">Create account</span>
      <span class="step-desc">Set up your email and password</span>
    </div>
  </li>
  <li class="step active">
    <div class="step-content">
      <span class="step-label">Add team members</span>
      <span class="step-desc">Invite colleagues</span>
    </div>
  </li>
</ol>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="full-example">
    <p class="text-xs font-semibold uppercase color-blue">Example</p>
    <h2>Full Multi-Step Form</h2>
    <p class="no-orphan">
      Combine step indicators with <code>step-panel</code> content sections
      and a <code>step-nav</code> footer for a complete wizard layout.
    </p>

    <div class="border border-radius padding padding-top-extra">
      <ol class="steps">
        <li class="step completed"><span class="step-label">Account</span></li>
        <li class="step active"><span class="step-label">Profile</span></li>
        <li class="step"><span class="step-label">Confirm</span></li>
      </ol>

      <div class="step-panel active">
        <form class="form">
          <label>
            Full Name
            <input type="text" placeholder="Jane Cooper" />
          </label>
          <label>
            Bio
            <textarea rows="3" placeholder="Tell us about yourself..."></textarea>
          </label>
        </form>
      </div>

      <div class="step-nav">
        <button class="btn btn-outline">Back</button>
        <button class="btn btn-blue">Continue</button>
      </div>
    </div>

    <CodeBlock code={`<ol class="steps">
  <li class="step completed"><span class="step-label">Account</span></li>
  <li class="step active"><span class="step-label">Profile</span></li>
  <li class="step"><span class="step-label">Confirm</span></li>
</ol>

<div class="step-panel active">
  <form class="form">
    <label>Full Name <input type="text"></label>
    <label>Bio <textarea></textarea></label>
  </form>
</div>

<div class="step-nav">
  <button class="btn btn-outline">Back</button>
  <button class="btn btn-blue">Continue</button>
</div>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra" id="reference">
    <p class="text-xs font-semibold uppercase color-blue">Reference</p>
    <h2>Class Reference</h2>

    <table class="table-stroked">
      <thead>
        <tr><th>Class</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>steps</code></td><td>Horizontal step indicator container</td></tr>
        <tr><td><code>steps-vertical</code></td><td>Vertical step layout modifier</td></tr>
        <tr><td><code>steps-sm</code></td><td>Smaller step circles and text</td></tr>
        <tr><td><code>step</code></td><td>Individual step item (auto-numbered)</td></tr>
        <tr><td><code>step.active</code></td><td>Current step (blue circle)</td></tr>
        <tr><td><code>step.completed</code></td><td>Completed step (green checkmark)</td></tr>
        <tr><td><code>step.step-error</code></td><td>Error step (red exclamation)</td></tr>
        <tr><td><code>step-label</code></td><td>Step title text</td></tr>
        <tr><td><code>step-desc</code></td><td>Step description text</td></tr>
        <tr><td><code>step-content</code></td><td>Wrapper for label + desc in vertical steps</td></tr>
        <tr><td><code>step-panel</code></td><td>Form content section (hidden by default)</td></tr>
        <tr><td><code>step-panel.active</code></td><td>Visible form panel</td></tr>
        <tr><td><code>step-nav</code></td><td>Back/Next button bar with top border</td></tr>
      </tbody>
    </table>
  </section>
</DocsLayout>
