---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";

const sampleData = [
  { name: "Jane Cooper", email: "jane@example.com", role: "Admin", status: "Active" },
  { name: "John Smith", email: "john@example.com", role: "Editor", status: "Active" },
  { name: "Bob Johnson", email: "bob@example.com", role: "Viewer", status: "Inactive" },
  { name: "Alice Williams", email: "alice@example.com", role: "Editor", status: "Active" },
  { name: "Charlie Brown", email: "charlie@example.com", role: "Viewer", status: "Pending" },
];
---

<DocsLayout title="Tables" description="Auto-styled tables with bordered, striped, hoverable, simple, and flat variants. Responsive container for overflow.">
  <section class="padding-top-extra padding-bottom-extra border-bottom">
    <p class="text-xs font-semibold uppercase color-blue">Data</p>
    <h1 class="text-balance">Tables</h1>
    <p class="lead no-orphan">
      Tables are styled automatically with semantic HTML. Add modifier
      classes for bordered, striped, hoverable, and simple variants.
    </p>
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="default"
  >
    <p class="text-xs font-semibold uppercase color-blue">Default</p>
    <h2>Standard Table</h2>

    <div class="border border-radius padding">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {sampleData.map((row) => (
            <tr>
              <td>{row.name}</td>
              <td>{row.email}</td>
              <td>{row.role}</td>
              <td>
                {row.status === "Active" ? (
                  <span class="success">● Active</span>
                ) : row.status === "Inactive" ? (
                  <span class="error">● Inactive</span>
                ) : (
                  <span>○ Pending</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <CodeBlock
      code={`<table>
  <thead>
    <tr><th>Name</th><th>Email</th><th>Role</th></tr>
  </thead>
  <tbody>
    <tr><td>Jane</td><td>jane@example.com</td><td>Admin</td></tr>
  </tbody>
</table>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="bordered"
  >
    <p class="text-xs font-semibold uppercase color-blue">Bordered</p>
    <h2>Bordered Table</h2>

    <div class="border border-radius padding">
      <table class="table-bordered">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {sampleData.slice(0, 3).map((row) => (
            <tr>
              <td>{row.name}</td>
              <td>{row.email}</td>
              <td>{row.role}</td>
              <td>{row.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <CodeBlock
      code={`<table class="table-bordered">
  <thead>
    <tr><th>Name</th><th>Email</th></tr>
  </thead>
  <tbody>
    <tr><td>Jane</td><td>jane@example.com</td></tr>
  </tbody>
</table>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="striped"
  >
    <p class="text-xs font-semibold uppercase color-blue">Striped</p>
    <h2>Striped Table</h2>

    <div class="border border-radius padding">
      <table class="table-stripped">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {sampleData.map((row) => (
            <tr>
              <td>{row.name}</td>
              <td>{row.email}</td>
              <td>{row.role}</td>
              <td>{row.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <CodeBlock
      code={`<table class="table-stripped">
  <thead>
    <tr><th>Name</th><th>Email</th><th>Role</th></tr>
  </thead>
  <tbody>
    <tr><td>Jane</td><td>jane@example.com</td><td>Admin</td></tr>
    <tr><td>John</td><td>john@example.com</td><td>Editor</td></tr>
  </tbody>
</table>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="hoverable"
  >
    <p class="text-xs font-semibold uppercase color-blue">
      Interactive
    </p>
    <h2>Hoverable Table</h2>
    <p>Hover over the rows to see the highlight effect.</p>

    <div class="border border-radius padding">
      <table class="table-hovered">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {sampleData.map((row) => (
            <tr>
              <td>{row.name}</td>
              <td>{row.email}</td>
              <td>{row.role}</td>
              <td>{row.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <CodeBlock
      code={`<table class="table-hovered">
  <thead>
    <tr><th>Name</th><th>Email</th><th>Role</th></tr>
  </thead>
  <tbody>
    <tr><td>Jane</td><td>jane@example.com</td><td>Admin</td></tr>
  </tbody>
</table>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="simple"
  >
    <p class="text-xs font-semibold uppercase color-blue">Minimal</p>
    <h2>Simple & Stroked Tables</h2>

    <div class="units-row">
      <div class="unit-50 phone-unit-100">
        <h3>Simple (no borders, no left padding)</h3>
        <div class="border border-radius padding">
          <table class="table-simple">
            <tbody>
              <tr>
                <td>Grid System</td>
                <td>16 widths</td>
              </tr>
              <tr>
                <td>Buttons</td>
                <td>6 colors</td>
              </tr>
              <tr>
                <td>Alerts</td>
                <td>5 variants</td>
              </tr>
              <tr>
                <td>Navigation</td>
                <td>6 types</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="unit-50 phone-unit-100">
        <h3>Stroked (bottom borders only)</h3>
        <div class="border border-radius padding">
          <table class="table-stroked">
            <tbody>
              <tr>
                <td>Typography</td>
                <td>9 sizes</td>
              </tr>
              <tr>
                <td>Helpers</td>
                <td>50+ classes</td>
              </tr>
              <tr>
                <td>Dark Mode</td>
                <td>Built-in</td>
              </tr>
              <tr>
                <td>Theming</td>
                <td>CSS vars</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <CodeBlock
      code={`<table class="table-simple">...</table>
<table class="table-stroked">...</table>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="flat"
  >
    <p class="text-xs font-semibold uppercase color-blue">Flat</p>
    <h2>Flat Table</h2>
    <p>
      No borders and no padding with <code>table-flat</code>.
    </p>

    <div class="border border-radius padding">
      <table class="table-flat">
        <thead>
          <tr>
            <th>Feature</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>AI-Native</td>
            <td>Ships PLY.md and ply-classes.json</td>
          </tr>
          <tr>
            <td>Accessible</td>
            <td>WCAG AA contrast by default</td>
          </tr>
          <tr>
            <td>Small</td>
            <td>~18KB gzipped full bundle</td>
          </tr>
        </tbody>
      </table>
    </div>

    <CodeBlock
      code={`<table class="table-flat">
  <thead>
    <tr><th>Feature</th><th>Description</th></tr>
  </thead>
  <tbody>
    <tr><td>AI-Native</td><td>Ships PLY.md and ply-classes.json</td></tr>
  </tbody>
</table>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="responsive"
  >
    <p class="text-xs font-semibold uppercase color-blue">Responsive</p>
    <h2>Responsive Table Container</h2>
    <p>
      Wrap tables in <code>table-container</code> for horizontal scrolling
      on small screens.
    </p>

    <div class="border border-radius padding">
      <div class="table-container">
        <table class="table-bordered">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Department</th>
              <th>Location</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>001</td>
              <td>Jane Cooper</td>
              <td>jane@example.com</td>
              <td>Admin</td>
              <td>Active</td>
              <td>Engineering</td>
              <td>New York</td>
              <td>2023-01-15</td>
            </tr>
            <tr>
              <td>002</td>
              <td>John Smith</td>
              <td>john@example.com</td>
              <td>Editor</td>
              <td>Active</td>
              <td>Design</td>
              <td>London</td>
              <td>2023-03-22</td>
            </tr>
            <tr>
              <td>003</td>
              <td>Bob Johnson</td>
              <td>bob@example.com</td>
              <td>Viewer</td>
              <td>Inactive</td>
              <td>Marketing</td>
              <td>Tokyo</td>
              <td>2022-11-08</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <CodeBlock
      code={`<div class="table-container">
  <table class="table-bordered">
    <!-- Wide table with horizontal scroll -->
  </table>
</div>`}
    />
  </section>

  <section class="padding-top-extra padding-bottom-extra" id="combined">
    <p class="text-xs font-semibold uppercase color-blue">Combined</p>
    <h2>Combined Modifiers</h2>
    <p>Classes can be combined for richer table styles.</p>

    <div class="border border-radius padding">
      <table class="table-bordered table-stripped table-hovered">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {sampleData.map((row) => (
            <tr>
              <td>{row.name}</td>
              <td>{row.email}</td>
              <td>{row.role}</td>
              <td>
                {row.status === "Active" ? (
                  <span class="success">● Active</span>
                ) : row.status === "Inactive" ? (
                  <span class="error">● Inactive</span>
                ) : (
                  <span>○ Pending</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <CodeBlock
      code={`<table class="table-bordered table-stripped table-hovered">
  <!-- Bordered + Striped + Hoverable -->
</table>`}
    />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="sort-indicators">
    <p class="text-xs font-semibold uppercase color-blue">Sorting</p>
    <h2>Sort Indicators</h2>
    <p class="no-orphan">
      Add <code>sortable</code> to <code>&lt;th&gt;</code> elements to show sort arrows.
      Toggle <code>sort-asc</code> or <code>sort-desc</code> to indicate the active sort direction.
    </p>

    <div class="border border-radius padding">
      <table class="table-stroked">
        <thead>
          <tr>
            <th class="sortable sort-asc">Name</th>
            <th class="sortable">Email</th>
            <th class="sortable sort-desc">Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Alice Williams</td><td>alice@example.com</td><td>Editor</td><td>Active</td></tr>
          <tr><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td><td>Inactive</td></tr>
          <tr><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td><td>Active</td></tr>
        </tbody>
      </table>
    </div>

    <CodeBlock code={`<table class="table-stroked">
  <thead>
    <tr>
      <th class="sortable sort-asc">Name</th>
      <th class="sortable">Email</th>
      <th class="sortable sort-desc">Role</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>...</tbody>
</table>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="table-filter">
    <p class="text-xs font-semibold uppercase color-blue">Filtering</p>
    <h2>Table Filter</h2>
    <p class="no-orphan">
      Add <code>table-filter</code> alongside <code>input-groups</code> to
      build a connected filter bar.
    </p>

    <div class="border border-radius padding">
      <div class="input-groups table-filter">
        <input type="text" placeholder="Search users..." aria-label="Search users" />
        <select aria-label="Filter by role">
          <option value="">All Roles</option>
          <option>Admin</option>
          <option>Editor</option>
          <option>Viewer</option>
        </select>
        <span class="btn-append">
          <button class="btn btn-primary">Filter</button>
        </span>
      </div>
      <table class="table-stroked table-hovered">
        <thead>
          <tr>
            <th class="sortable">Name</th>
            <th class="sortable">Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td><td><span class="success">Active</span></td></tr>
          <tr><td>John Smith</td><td>john@example.com</td><td>Editor</td><td><span class="success">Active</span></td></tr>
          <tr><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td><td><span class="error">Inactive</span></td></tr>
        </tbody>
      </table>
    </div>

    <CodeBlock code={`<div class="input-groups table-filter">
  <input type="text" placeholder="Search..." aria-label="Search">
  <select aria-label="Filter by role">
    <option value="">All Roles</option>
    <option>Admin</option>
  </select>
  <span class="btn-append">
    <button class="btn btn-primary">Filter</button>
  </span>
</div>
<table class="table-stroked table-hovered">...</table>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="table-actions">
    <p class="text-xs font-semibold uppercase color-blue">Actions</p>
    <h2>Table Actions</h2>
    <p class="no-orphan">
      Use <code>table-actions</code> for right-aligned icon buttons above a table.
    </p>

    <div class="border border-radius padding">
      <div class="table-actions">
        <button class="btn btn-ghost btn-icon" aria-label="Download" title="Download">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
        <button class="btn btn-ghost btn-icon" aria-label="Print" title="Print">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        </button>
        <button class="btn btn-ghost btn-icon" aria-label="Delete selected" title="Delete selected">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
        </button>
      </div>
      <table class="table-stroked">
        <thead>
          <tr>
            <th style="width: 2rem"><input type="checkbox" aria-label="Select all" /></th>
            <th class="sortable">Name</th>
            <th class="sortable">Email</th>
            <th>Role</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><input type="checkbox" aria-label="Select row" /></td><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td></tr>
          <tr><td><input type="checkbox" aria-label="Select row" /></td><td>John Smith</td><td>john@example.com</td><td>Editor</td></tr>
          <tr><td><input type="checkbox" aria-label="Select row" /></td><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td></tr>
        </tbody>
      </table>
    </div>

    <CodeBlock code={`<div class="table-actions">
  <button class="btn btn-ghost btn-icon" aria-label="Download">...</button>
  <button class="btn btn-ghost btn-icon" aria-label="Print">...</button>
</div>
<table class="table-stroked">...</table>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="pagination">
    <p class="text-xs font-semibold uppercase color-blue">Navigation</p>
    <h2>Pagination</h2>

    <div class="border border-radius padding">
      <table class="table-stroked table-hovered">
        <thead>
          <tr>
            <th class="sortable sort-asc">Name</th>
            <th class="sortable">Email</th>
            <th>Role</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Jane Cooper</td><td>jane@example.com</td><td>Admin</td><td><span class="success">Active</span></td></tr>
          <tr><td>John Smith</td><td>john@example.com</td><td>Editor</td><td><span class="success">Active</span></td></tr>
          <tr><td>Bob Johnson</td><td>bob@example.com</td><td>Viewer</td><td><span class="error">Inactive</span></td></tr>
        </tbody>
      </table>
      <div class="display-flex items-center justify-between flex-wrap gap margin-top">
        <span class="pagination-info">Showing 1–3 of 48</span>
        <nav aria-label="Table pagination">
          <ul class="pagination">
            <li class="disabled"><span aria-disabled="true">&laquo;</span></li>
            <li class="active"><a href="#pagination" aria-current="page">1</a></li>
            <li><a href="#pagination">2</a></li>
            <li><a href="#pagination">3</a></li>
            <li><a href="#pagination">...</a></li>
            <li><a href="#pagination">16</a></li>
            <li><a href="#pagination">&raquo;</a></li>
          </ul>
        </nav>
      </div>
    </div>

    <CodeBlock code={`<ul class="pagination">
  <li class="active"><a href="#" aria-current="page">1</a></li>
  <li><a href="#">2</a></li>
  <li><a href="#">3</a></li>
</ul>

<!-- Solid variant -->
<ul class="pagination pagination-solid">...</ul>

<!-- Sizes -->
<ul class="pagination pagination-sm">...</ul>
<ul class="pagination pagination-lg">...</ul>`} />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra"
    id="next-steps"
  >
    <p class="text-xs font-semibold uppercase color-blue">Next</p>
    <h2>Next Steps</h2>
    <p class="text-secondary no-orphan">
      Add feedback with <a href="/docs/alerts">alerts & dialogs</a>, or
      explore <a href="/docs/utilities">utility classes</a> for
      spacing, display, and more.
    </p>
  </section>
</DocsLayout>
