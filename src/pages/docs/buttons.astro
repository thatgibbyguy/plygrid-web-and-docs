---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<DocsLayout title="Buttons" description="Button styles in ply — 6 colors, outline and ghost variants, sizes from xs to lg, groups, and icon buttons.">
  <section class="padding-top-extra padding-bottom-extra border-bottom">
    <p class="text-xs font-semibold uppercase color-blue">Components</p>
    <h1 class="text-balance">Buttons</h1>
    <p class="lead no-orphan">
      Primary and secondary actions, static color variants, outline and ghost
      styles, four sizes, button groups, and full keyboard accessibility out of
      the box.
    </p>
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="button-primary-secondary"
  >
    <p class="text-xs font-semibold uppercase color-blue">Themeable</p>
    <h2>Primary & Secondary</h2>
    <p class="no-orphan">
      Use <code>btn-primary</code> for the main call-to-action and
      <code>btn-secondary</code> (or plain <code>btn</code>) for secondary
      actions. Both respond to custom themes via <code>--ply-btn-default-bg</code>
      and <code>--ply-btn-secondary-bg</code>.
    </p>

    <div class="border border-radius padding">
      <button class="btn btn-primary">Primary</button>
      <button class="btn btn-secondary">Secondary</button>
      <button class="btn btn-primary-outline">Primary Outline</button>
      <button class="btn btn-secondary-outline">Secondary Outline</button>
      <button class="btn btn-ghost">Ghost</button>
    </div>

    <CodeBlock
      code={`<button class="btn btn-primary">Primary</button>
<button class="btn btn-secondary">Secondary</button>
<button class="btn btn-primary-outline">Primary Outline</button>
<button class="btn btn-secondary-outline">Secondary Outline</button>
<button class="btn btn-ghost">Ghost</button>`}
    />

    <h3>Theming</h3>
    <p class="no-orphan">
      Override <code>--ply-btn-default-bg</code> in a custom theme to change the
      primary button and link colors together. Secondary follows
      <code>--ply-btn-secondary-bg</code>. Color buttons (<code>btn-blue</code>,
      etc.) are immune to theming.
    </p>

    <div class="border border-radius padding">
      <div class="btn-group" role="group" aria-label="Theme selection">
        <button class="btn btn-primary" data-theme-btn="default" aria-pressed="true">Default Theme</button>
        <button class="btn btn-secondary" data-theme-btn="warm" aria-pressed="false">Warm Theme</button>
      </div>
    </div>

    <CodeBlock
      code={`[data-theme="warm"] {
  --ply-btn-default-bg: #92400e;   /* Primary button + links */
  --ply-btn-secondary-bg: #78350f; /* Secondary button */
  --ply-btn-default-color: #fff;   /* Primary text */
  --ply-btn-secondary-color: #fff; /* Secondary text */
}
/* See Colors & Theming for the full warm theme definition. */`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="button-colors"
  >
    <p class="text-xs font-semibold uppercase color-blue">Static</p>
    <h2>Color Variants</h2>
    <p class="no-orphan">
      Static color buttons use hardcoded values and are immune to theming. Use
      them for color-coded actions (e.g., delete&nbsp;=&nbsp;red,
      success&nbsp;=&nbsp;green).
    </p>

    <div class="border border-radius padding">
      <button class="btn btn-blue">Blue</button> <button class="btn btn-red">Red</button> <button class="btn btn-green">Green</button> <button class="btn btn-yellow">Yellow</button> <button class="btn btn-black">Black</button> <button class="btn btn-white">White</button>
    </div>

    <CodeBlock
      code={`<button class="btn btn-blue">Blue</button>
<button class="btn btn-red">Red</button>
<button class="btn btn-green">Green</button>
<button class="btn btn-yellow">Yellow</button>
<button class="btn btn-black">Black</button>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="button-outline"
  >
    <p class="text-xs font-semibold uppercase color-blue">Variants</p>
    <h2>Outline Buttons</h2>

    <div class="border border-radius padding">
      <button class="btn btn-outline">Outline</button> <button class="btn btn-outline bold">Outline Bold</button>
    </div>

    <CodeBlock
      code={`<button class="btn btn-outline">Outline</button>
<button class="btn btn-outline bold">Outline Bold</button>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="button-ghost"
  >
    <p class="text-xs font-semibold uppercase color-blue">Variants</p>
    <h2>Ghost Buttons</h2>
    <p class="no-orphan">
      Transparent background with no border. Subtle hover background for
      low-emphasis actions.
    </p>

    <div class="border border-radius padding display-flex items-center gap-sm">
      <button class="btn btn-ghost">Ghost</button> <button class="btn btn-ghost btn-sm">Ghost Small</button> <button class="btn btn-ghost btn-icon" aria-label="Icon button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </div>

    <CodeBlock code={`<button class="btn btn-ghost">Ghost</button>
<!-- Icon-only: equal padding, square shape -->
<button class="btn btn-ghost btn-icon" aria-label="Search">
  <svg>...</svg>
</button>`} />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="button-sizes"
  >
    <p class="text-xs font-semibold uppercase color-blue">Sizes</p>
    <h2>Button Sizes</h2>

    <div class="border border-radius padding">
      <button class="btn btn-primary btn-lg">Large (btn-lg)</button> <button class="btn btn-primary">Default</button> <button class="btn btn-primary btn-sm">Small (btn-sm)</button> <button class="btn btn-primary btn-xs">
        Extra Small (btn-xs)
      </button>
    </div>

    <table>
      <thead>
        <tr>
          <th>Class</th>
          <th>Alias</th>
          <th>Size</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>
            <code>btn-lg</code>
          </td>
          <td>
            <code>btn-lg</code>
          </td>
          <td>Large</td>
        </tr>
        <tr>
          <td>(default)</td>
          <td>—</td>
          <td>Normal</td>
        </tr>
        <tr>
          <td>
            <code>btn-sm</code>
          </td>
          <td>
            <code>btn-sm</code>
          </td>
          <td>Small</td>
        </tr>
        <tr>
          <td>
            <code>btn-xs</code>
          </td>
          <td>
            <code>btn-xs</code>
          </td>
          <td>Extra small</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="button-states"
  >
    <p class="text-xs font-semibold uppercase color-blue">States</p>
    <h2>Active & Disabled</h2>

    <div class="border border-radius padding">
      <button class="btn btn-active">Active</button> <button class="btn btn-disabled">Disabled</button> <button class="btn btn-primary" disabled>
        Native Disabled
      </button>
    </div>

    <CodeBlock
      code={`<button class="btn btn-active">Active</button>
<button class="btn btn-disabled">Disabled</button>
<button class="btn" disabled>Native Disabled</button>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="button-shapes"
  >
    <p class="text-xs font-semibold uppercase color-blue">Shapes</p>
    <h2>Square Buttons</h2>

    <div class="border border-radius padding">
      <button class="btn btn-primary btn-straight">Square Corners (btn-straight)</button> <button class="btn btn-outline btn-square">
        Alias: btn-square
      </button>
    </div>

    <h3>Single Button Container</h3>
    <div class="border border-radius padding">
      <div class="btn-single">
        <button class="btn btn-primary">Single Button</button>
      </div>
    </div>

    <CodeBlock
      code={`<button class="btn btn-primary btn-straight">No border-radius</button>
<button class="btn btn-square">Alias for btn-straight</button>

<div class="btn-single">
  <button class="btn btn-primary">Single Button</button>
</div>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra"
    id="button-groups"
  >
    <p class="text-xs font-semibold uppercase color-blue">Groups</p>
    <h2>Button Groups</h2>

    <div class="border border-radius padding">
      <div class="btn-group">
        <button class="btn btn-primary">Save</button>
        <button class="btn">Cancel</button>
        <button class="btn btn-red">Delete</button>
      </div>
    </div>

    <h3>Aligned Groups</h3>
    <div class="border border-radius padding">
      <div class="btn-group align-left">
        <button class="btn btn-sm">Left</button>
        <button class="btn btn-sm">Aligned</button>
      </div>
      <div class="btn-group align-center">
        <button class="btn btn-sm">Center</button>
        <button class="btn btn-sm">Aligned</button>
      </div>
      <div class="btn-group align-right">
        <button class="btn btn-sm">Right</button>
        <button class="btn btn-sm">Aligned</button>
      </div>
    </div>

    <h3>Joined</h3>
    <p class="no-orphan">
      Add <code>joined</code> to connect buttons with no gap. A 1px divider
      separates buttons; border-radius is applied only to the outer edges. Use
      for segmented controls, toolbars, and pagination-style groups.
    </p>
    <div class="border border-radius padding">
      <div class="btn-group joined">
        <button class="btn">Week</button>
        <button class="btn btn-primary">Month</button>
        <button class="btn">Year</button>
      </div>
      <div class="margin-bottom-lg"></div>
      <div class="btn-group joined">
        <button class="btn btn-ghost btn-icon" aria-label="Bold">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
        </button>
        <button class="btn btn-ghost btn-icon" aria-label="Italic">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>
        </button>
        <button class="btn btn-ghost btn-icon" aria-label="Underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 0 0 6 6 6 6 0 0 0 6-6V3"/><line x1="4" y1="21" x2="20" y2="21"/></svg>
        </button>
      </div>
    </div>

    <h3>Full Width & Rounded</h3>
    <div class="border border-radius padding">
      <div class="btn-group fill-width">
        <button class="btn btn-primary">Option A</button>
        <button class="btn">Option B</button>
        <button class="btn">Option C</button>
      </div>
      <div class="margin-bottom-lg"></div>
      <div class="btn-group rounded">
        <button class="btn btn-sm">Rounded</button>
        <button class="btn btn-sm">Group</button>
        <button class="btn btn-sm">Buttons</button>
      </div>
    </div>

    <CodeBlock
      code={`<div class="btn-group">
  <button class="btn btn-primary">Save</button>
  <button class="btn">Cancel</button>
</div>

<!-- Joined: no gap, connected edges -->
<div class="btn-group joined">
  <button class="btn">Week</button>
  <button class="btn btn-primary">Month</button>
  <button class="btn">Year</button>
</div>

<div class="btn-group fill-width">
  <button class="btn">Full</button>
  <button class="btn">Width</button>
</div>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra"
    id="next-steps"
  >
    <p class="text-xs font-semibold uppercase color-blue">Next</p>
    <h2>Next Steps</h2>
    <p class="text-secondary no-orphan">
      Build <a href="/docs/forms">forms</a> with styled inputs and
      validation, or add <a href="/docs/navigation">navigation</a> to
      your layout.
    </p>
  </section>
</DocsLayout>

<script>
  let savedTheme: string | null = null;

  document.querySelectorAll('[data-theme-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const value = (btn as HTMLElement).dataset.themeBtn;
      if (value === 'warm') {
        savedTheme = document.documentElement.getAttribute('data-theme');
        document.documentElement.setAttribute('data-theme', 'warm');
      } else {
        if (savedTheme) {
          document.documentElement.setAttribute('data-theme', savedTheme);
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
        savedTheme = null;
      }
      document.querySelectorAll('[data-theme-btn]').forEach(b => {
        const isActive = (b as HTMLElement).dataset.themeBtn === value;
        b.setAttribute('aria-pressed', String(isActive));
        b.classList.toggle('btn-primary', isActive);
        b.classList.toggle('btn-secondary', !isActive);
      });
    });
  });
</script>

<style is:global>
  [data-theme="warm"] {
    --ply-bg-body: #faf5f0;
    --ply-bg-surface: #f5ebe0;
    --ply-bg-surface-alt: #ede0d4;
    --ply-bg-muted: #e6d5c3;
    --ply-color-body: #1c1917;
    --ply-color-headings: #44240e;
    --ply-color-secondary: #6b4226;
    --ply-color-muted: #8b6f56;
    --ply-color-placeholder: #a89279;
    --ply-color-text-inverse: #fff;
    --ply-border-color: #d4a574;
    --ply-border-strong: #a87c4f;
    --ply-color-link: var(--ply-btn-default-bg);
    --ply-color-link-hover: #78350f;
    --ply-color-focus: #92400e;
    --ply-btn-default-bg: #92400e;
    --ply-btn-secondary-bg: #78350f;
    --ply-btn-default-color: #fff;
    --ply-btn-secondary-color: #fff;
    --ply-nav-bg: #f5ebe0;
    --ply-nav-color: #1c1917;
    --ply-nav-border: #c2956b;
    --ply-nav-hover: #ede0d4;
    --ply-color-field-bg: #f5ebe0;
    --ply-color-input-border: #c2956b;
    --ply-color-input-bg: #faf5f0;
    --ply-color-code-bg: #f5ebe0;
    --ply-color-code-border: #d4a574;
    --ply-layer-0: #faf5f0;
    --ply-layer-1: #f5ebe0;
    --ply-layer-2: #ede0d4;
    --ply-font-body: Palatino, "Palatino Linotype", Georgia, serif;
    --ply-font-heading: Palatino, "Palatino Linotype", Georgia, serif;
  }
</style>
