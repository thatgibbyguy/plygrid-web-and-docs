---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<DocsLayout title="Forms">
      <section class="padding-top-extra padding-bottom-extra border-bottom">
        <p class="text-xs font-semibold uppercase color-blue">Components</p>
        <h1 class="text-balance">Forms</h1>
        <p class="lead no-orphan">
          Styled inputs, selects, textareas, validation states, input groups,
          and layout options — all activated by wrapping in <code>.form</code>.
        </p>
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="forms"
      >
        <p class="text-xs font-semibold uppercase color-blue">Basics</p>
        <h2>Standard Form</h2>

        <div class="border border-radius padding">
          <div class="units-row">
            <div class="unit-60 phone-unit-100">
              <form class="form">
                <label>
                  Full Name
                  <input type="text" placeholder="Jane Cooper" />
                </label>
                <label>
                  Email Address
                  <input type="email" placeholder="jane@example.com" />
                </label>
                <label>
                  Subject
                  <select>
                    <option value="">Choose a topic...</option>
                    <option>General Inquiry</option>
                    <option>Technical Support</option>
                    <option>Feedback</option>
                  </select>
                </label>
                <label>
                  Message
                  <textarea rows="4" placeholder="Your message..."></textarea>
                </label>
                <button class="btn btn-blue" type="submit">
                  Send Message
                </button>
              </form>
            </div>
          </div>
        </div>

        <CodeBlock
          code={`<form class="form">
  <label>
    Email
    <input type="email" placeholder="you@example.com">
  </label>
  <label>
    Message
    <textarea></textarea>
  </label>
  <button class="btn btn-blue" type="submit">Send</button>
</form>`}
        />
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="input-sizes"
      >
        <p class="text-xs font-semibold uppercase color-blue">Sizes</p>
        <h2>Input Sizes</h2>

        <div class="border border-radius padding">
          <form class="form">
            <label>
              Large Input
              <input
                type="text"
                class="input-big"
                placeholder="input-big / input-lg"
              />
            </label>
            <label>
              Default Input
              <input type="text" placeholder="Default size" />
            </label>
            <label>
              Small Input
              <input
                type="text"
                class="input-small"
                placeholder="input-small / input-sm"
              />
            </label>
            <label>
              Extra Small Input
              <input
                type="text"
                class="input-smaller"
                placeholder="input-smaller / input-xs"
              />
            </label>
          </form>
        </div>
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="input-states"
      >
        <p class="text-xs font-semibold uppercase color-blue">Validation</p>
        <h2>Input States</h2>

        <div class="border border-radius padding">
          <form class="form">
            <label>
              Error State
              <input
                type="text"
                class="input-error"
                value="invalid@email"
              />
            </label>
            <label>
              Success State
              <input
                type="text"
                class="input-success"
                value="valid@email.com"
              />
            </label>
            <label>
              Gray / Neutral State
              <input
                type="text"
                class="input-gray"
                placeholder="Neutral input"
              />
            </label>
          </form>
        </div>

        <CodeBlock
          code={`<input type="text" class="input-error" value="Invalid">
<input type="text" class="input-success" value="Valid">
<input type="text" class="input-gray" placeholder="Neutral">`}
        />
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="input-groups"
      >
        <p class="text-xs font-semibold uppercase color-blue">Groups</p>
        <h2>Input Groups</h2>

        <div class="border border-radius padding">
          <form class="form">
            <div class="input-groups">
              <span class="input-prepend">$</span>
              <input type="text" placeholder="Amount" aria-label="Dollar amount" />
              <span class="input-append">.00</span>
            </div>
            <div class="bottom-margin-extra"></div>
            <div class="input-groups">
              <span class="input-prepend">https://</span>
              <input type="text" placeholder="example.com" aria-label="Website URL" />
            </div>
            <div class="bottom-margin-extra"></div>
            <div class="input-groups">
              <input type="text" placeholder="Search..." aria-label="Search" />
              <span class="input-append">
                <button class="btn btn-blue btn-sm">Go</button>
              </span>
            </div>
          </form>
        </div>

        <CodeBlock
          code={`<div class="input-groups">
  <span class="input-prepend">$</span>
  <input type="text" placeholder="Amount">
  <span class="input-append">.00</span>
</div>`}
        />
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="checkboxes"
      >
        <p class="text-xs font-semibold uppercase color-blue">Controls</p>
        <h2>Checkboxes & Radios</h2>

        <div class="border border-radius padding">
          <form class="form">
            <div class="units-row">
              <div class="unit-50 phone-unit-100">
                <p class="h4">Checkboxes</p>
                <label>
                  <input type="checkbox" checked /> Grid System
                </label>
                <label>
                  <input type="checkbox" checked /> Typography
                </label>
                <label>
                  <input type="checkbox" /> Forms
                </label>
                <label>
                  <input type="checkbox" /> Navigation
                </label>
              </div>
              <div class="unit-50 phone-unit-100">
                <p class="h4">Radio Buttons</p>
                <label>
                  <input type="radio" name="plan" checked /> Starter
                </label>
                <label>
                  <input type="radio" name="plan" /> Professional
                </label>
                <label>
                  <input type="radio" name="plan" /> Enterprise
                </label>
              </div>
            </div>
          </form>
        </div>
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="form-layouts"
      >
        <p class="text-xs font-semibold uppercase color-blue">Layouts</p>
        <h2>Form Layouts</h2>

        <h3>Inline Form</h3>
        <div class="border border-radius padding">
          <form
            class="form form-inline"
          >
            <input type="text" placeholder="Name" aria-label="Name" />
            <input type="email" placeholder="Email" aria-label="Email" />
            <button class="btn btn-blue" type="submit">
              Subscribe
            </button>
          </form>
        </div>

        <CodeBlock
          code={`<form class="form form-inline">
  <input type="text" placeholder="Name">
  <input type="email" placeholder="Email">
  <button class="btn btn-blue">Subscribe</button>
</form>`}
        />
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="form-reference"
      >
        <p class="text-xs font-semibold uppercase color-blue">Reference</p>
        <h2>Form Class Reference</h2>

        <h3>Layout</h3>
        <table class="table-stroked">
          <tbody>
            <tr><td><code>form</code></td><td>Base wrapper — enables styled inputs</td></tr>
            <tr><td><code>form-inline</code></td><td>Inline horizontal form</td></tr>
            <tr><td><code>form-inline-list</code></td><td>Inline form as list</td></tr>
            <tr><td><code>form-list</code></td><td>Vertical stacked form list</td></tr>
            <tr><td><code>form-desc</code></td><td>Help/description text below inputs</td></tr>
          </tbody>
        </table>

        <h3>Input Variants</h3>
        <table class="table-stroked">
          <tbody>
            <tr><td><code>input-search</code></td><td>Rounded pill-shaped search input</td></tr>
            <tr><td><code>input-on-black</code></td><td>Input for dark backgrounds</td></tr>
            <tr><td><code>select-outlined</code></td><td>Transparent select with visible border</td></tr>
            <tr><td><code>btn-append</code></td><td>Button appended to input group</td></tr>
          </tbody>
        </table>

        <h3>Autocomplete & Typeahead</h3>
        <table class="table-stroked">
          <tbody>
            <tr><td><code>autocomplete</code></td><td>Autocomplete dropdown container</td></tr>
            <tr><td><code>typeahead</code></td><td>Typeahead wrapper (alias: livesearch-container)</td></tr>
            <tr><td><code>typeahead-results</code></td><td>Results dropdown</td></tr>
            <tr><td><code>typeahead-empty</code></td><td>Empty results message</td></tr>
            <tr><td><code>filterbox</code></td><td>Filterable input wrapper</td></tr>
            <tr><td><code>filterbox-list</code></td><td>Filter dropdown list</td></tr>
          </tbody>
        </table>

        <h3>Multi-select</h3>
        <table class="table-stroked">
          <tbody>
            <tr><td><code>multiselect</code></td><td>Multi-select wrapper</td></tr>
            <tr><td><code>multiselect-tags</code></td><td>Tag container</td></tr>
            <tr><td><code>multiselect-tag</code></td><td>Individual tag</td></tr>
            <tr><td><code>multiselect-results</code></td><td>Results dropdown</td></tr>
          </tbody>
        </table>

        <h3>File Upload</h3>
        <table class="table-stroked">
          <tbody>
            <tr><td><code>tools-droparea</code></td><td>Drag-and-drop upload area</td></tr>
            <tr><td><code>tools-droparea-placeholder</code></td><td>Placeholder text</td></tr>
          </tbody>
        </table>
      </section>

      <section
        class="padding-top-extra padding-bottom-extra border-bottom"
        id="datepicker"
      >
        <p class="text-xs font-semibold uppercase color-blue">Native</p>
        <h2>Date & Time Pickers</h2>
        <p class="no-orphan">
          Native HTML date and time inputs are styled automatically by ply
          inside a <code>.form</code> wrapper. No JavaScript datepicker library needed — the
          browser provides an accessible, localizable picker.
        </p>

        <div class="border border-radius padding">
          <form class="form">
            <div class="units-row">
              <div class="unit-50 phone-unit-100">
                <label>
                  Date
                  <input type="date" />
                </label>
                <label>
                  Date &amp; Time
                  <input type="datetime-local" />
                </label>
                <label>
                  Month
                  <input type="month" />
                </label>
              </div>
              <div class="unit-50 phone-unit-100">
                <label>
                  Time
                  <input type="time" />
                </label>
                <label>
                  Date Range (start)
                  <input type="date" />
                </label>
                <label>
                  Date Range (end)
                  <input type="date" />
                </label>
              </div>
            </div>
          </form>
        </div>

        <CodeBlock
          code={`<form class="form">
  <label>
    Date
    <input type="date">
  </label>
  <label>
    Date & Time
    <input type="datetime-local">
  </label>
  <label>
    Time
    <input type="time">
  </label>
  <label>
    Month
    <input type="month">
  </label>
</form>`}
        />

        <h3>With Validation States</h3>
        <div class="border border-radius padding">
          <form class="form">
            <div class="units-row">
              <div class="unit-33 phone-unit-100">
                <label>
                  Start Date
                  <input type="date" class="input-success" value="2026-03-01" />
                </label>
                <span class="success">Valid date</span>
              </div>
              <div class="unit-33 phone-unit-100">
                <label>
                  End Date
                  <input type="date" class="input-error" value="2026-02-15" />
                </label>
                <span class="error">End must be after start</span>
              </div>
              <div class="unit-33 phone-unit-100">
                <label>
                  Optional Date
                  <input type="date" class="input-gray" />
                </label>
                <span class="form-desc">Leave blank if not applicable</span>
              </div>
            </div>
          </form>
        </div>

        <CodeBlock
          code={`<label>
  Start Date
  <input type="date" class="input-success" value="2026-03-01">
</label>
<span class="success">Valid date</span>

<label>
  End Date
  <input type="date" class="input-error" value="2026-02-15">
</label>
<span class="error">End must be after start</span>`}
        />
      </section>

      <section class="padding-top-extra padding-bottom-extra" id="dialog">
        <p class="text-xs font-semibold uppercase color-blue">Modal</p>
        <h2>Dialog Element</h2>
        <p>Native HTML dialog element, styled automatically by ply.</p>

        <div class="border border-radius padding">
          <button
            class="btn btn-blue"
            onclick="document.getElementById('demo-dialog').showModal()"
          >
            Open Dialog
          </button>
          <dialog id="demo-dialog" aria-labelledby="demo-dialog-title">
            <h3 id="demo-dialog-title">Dialog Title</h3>
            <p>
              This is a native HTML dialog element styled by ply. No JavaScript
              framework needed for the styling.
            </p>
            <form class="form">
              <label>
                Your feedback
                <textarea rows="3" placeholder="Type here..."></textarea>
              </label>
            </form>
            <div class="btn-group align-right">
              <button
                class="btn btn-outline"
                onclick="document.getElementById('demo-dialog').close()"
              >
                Cancel
              </button>
              <button
                class="btn btn-blue"
                onclick="document.getElementById('demo-dialog').close()"
              >
                Submit
              </button>
            </div>
          </dialog>
        </div>
      </section>

      <section
        class="padding-top-extra padding-bottom-extra"
        id="next-steps"
      >
        <p class="text-xs font-semibold uppercase color-blue">Next</p>
        <h2>Next Steps</h2>
        <p class="text-secondary no-orphan">
          Add <a href="/docs/navigation">navigation</a> to your layout, or
          display data with <a href="/docs/tables">tables</a>.
        </p>
      </section>
</DocsLayout>
