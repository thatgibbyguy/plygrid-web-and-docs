---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<DocsLayout title="Dialogs & Alerts" description="Native dialog patterns, alert banners, labels, badges, and toast messages with accessibility guidance.">
  <section class="padding-top-extra padding-bottom-extra border-bottom">
    <p class="text-xs font-semibold uppercase color-blue">Components</p>
    <h1 class="text-balance">Dialogs & Alerts</h1>
    <p class="lead no-orphan">
      Native dialog patterns — sizes, scrollable, confirmation, and stacked —
      plus notification banners, inline labels, and toast messages.
    </p>
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="structured">
    <p class="text-xs font-semibold uppercase color-blue">Dialogs</p>
    <h2>Structured Dialog</h2>
    <p class="no-orphan">
      Use <code>dialog-header</code>, <code>dialog-body</code>, and <code>dialog-footer</code> for
      a consistent header/body/footer layout.
    </p>

    <div class="border border-radius padding">
      <button class="btn btn-primary" onclick="document.getElementById('structured-dialog').showModal()">
        Open Structured Dialog
      </button>
      <dialog id="structured-dialog" aria-labelledby="structured-title">
        <div class="dialog-header">
          <h3 id="structured-title">Edit Profile</h3>
          <button class="dialog-close" onclick="document.getElementById('structured-dialog').close()" aria-label="Close">&times;</button>
        </div>
        <div class="dialog-body">
          <form class="form">
            <label>Display Name <input type="text" placeholder="Jane Cooper" /></label>
            <label>Email <input type="email" placeholder="jane@example.com" /></label>
          </form>
        </div>
        <div class="dialog-footer">
          <button class="btn btn-secondary" onclick="document.getElementById('structured-dialog').close()">Cancel</button>
          <button class="btn btn-primary" onclick="document.getElementById('structured-dialog').close()">Save</button>
        </div>
      </dialog>
    </div>

    <CodeBlock code={`<dialog id="my-dialog" aria-labelledby="dialog-title">
  <div class="dialog-header">
    <h3 id="dialog-title">Edit Profile</h3>
    <button class="dialog-close" aria-label="Close">&times;</button>
  </div>
  <div class="dialog-body">
    <form class="form">...</form>
  </div>
  <div class="dialog-footer">
    <button class="btn btn-secondary">Cancel</button>
    <button class="btn btn-primary">Save</button>
  </div>
</dialog>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="dialog-sizes">
    <p class="text-xs font-semibold uppercase color-blue">Sizes</p>
    <h2>Dialog Sizes</h2>

    <div class="border border-radius padding display-flex gap-sm flex-wrap">
      <button class="btn btn-sm" onclick="document.getElementById('sm-dialog').showModal()">Small</button>
      <button class="btn btn-sm" onclick="document.getElementById('default-dialog').showModal()">Default</button>
      <button class="btn btn-sm" onclick="document.getElementById('lg-dialog').showModal()">Large</button>

      <dialog id="sm-dialog" class="dialog-sm" aria-label="Small dialog">
        <div class="dialog-header">
          <h3>Small Dialog</h3>
          <button class="dialog-close" onclick="document.getElementById('sm-dialog').close()" aria-label="Close">&times;</button>
        </div>
        <div class="dialog-body"><p>Max-width 24rem.</p></div>
        <div class="dialog-footer">
          <button class="btn btn-primary btn-sm" onclick="document.getElementById('sm-dialog').close()">OK</button>
        </div>
      </dialog>

      <dialog id="default-dialog" aria-label="Default dialog">
        <div class="dialog-header">
          <h3>Default Dialog</h3>
          <button class="dialog-close" onclick="document.getElementById('default-dialog').close()" aria-label="Close">&times;</button>
        </div>
        <div class="dialog-body"><p>Default browser width for <code>&lt;dialog&gt;</code>.</p></div>
        <div class="dialog-footer">
          <button class="btn btn-primary btn-sm" onclick="document.getElementById('default-dialog').close()">OK</button>
        </div>
      </dialog>

      <dialog id="lg-dialog" class="dialog-lg" aria-label="Large dialog">
        <div class="dialog-header">
          <h3>Large Dialog</h3>
          <button class="dialog-close" onclick="document.getElementById('lg-dialog').close()" aria-label="Close">&times;</button>
        </div>
        <div class="dialog-body"><p>Max-width 48rem.</p></div>
        <div class="dialog-footer">
          <button class="btn btn-primary btn-sm" onclick="document.getElementById('lg-dialog').close()">OK</button>
        </div>
      </dialog>
    </div>

    <CodeBlock code={`<dialog class="dialog-sm">...</dialog>  <!-- 24rem -->
<dialog>...</dialog>                     <!-- Default -->
<dialog class="dialog-lg">...</dialog>   <!-- 48rem -->
<dialog class="dialog-full">...</dialog> <!-- Viewport -->`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="dialog-confirm">
    <p class="text-xs font-semibold uppercase color-blue">Pattern</p>
    <h2>Confirmation Dialog</h2>

    <div class="border border-radius padding">
      <button class="btn btn-red btn-outline" onclick="document.getElementById('confirm-dialog').showModal()">Delete Item</button>
      <dialog id="confirm-dialog" class="dialog-confirm" aria-labelledby="confirm-title">
        <div class="dialog-body">
          <h3 id="confirm-title">Delete this item?</h3>
          <p class="text-secondary">This action cannot be undone.</p>
        </div>
        <div class="dialog-footer">
          <button class="btn btn-secondary" onclick="document.getElementById('confirm-dialog').close()">Cancel</button>
          <button class="btn btn-red" onclick="document.getElementById('confirm-dialog').close()">Delete</button>
        </div>
      </dialog>
    </div>

    <CodeBlock code={`<dialog class="dialog-confirm" aria-labelledby="confirm-title">
  <div class="dialog-body">
    <h3 id="confirm-title">Delete this item?</h3>
    <p class="text-secondary">This cannot be undone.</p>
  </div>
  <div class="dialog-footer">
    <button class="btn btn-secondary">Cancel</button>
    <button class="btn btn-red">Delete</button>
  </div>
</dialog>`} />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="dialog-scroll">
    <p class="text-xs font-semibold uppercase color-blue">Pattern</p>
    <h2>Scrollable Dialog</h2>

    <div class="border border-radius padding">
      <button class="btn btn-primary" onclick="document.getElementById('scroll-dialog').showModal()">Open Scrollable Dialog</button>
      <dialog id="scroll-dialog" class="dialog-scroll" aria-labelledby="scroll-title">
        <div class="dialog-header">
          <h3 id="scroll-title">Terms of Service</h3>
          <button class="dialog-close" onclick="document.getElementById('scroll-dialog').close()" aria-label="Close">&times;</button>
        </div>
        <div class="dialog-body">
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
          <p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.</p>
          <p>Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium.</p>
          <p>Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit.</p>
          <p>At vero eos et accusamus et iusto odio dignissimos ducimus qui blanditiis praesentium voluptatum.</p>
          <p>Similique sunt in culpa qui officia deserunt mollitia animi, id est laborum et dolorum fuga.</p>
        </div>
        <div class="dialog-footer">
          <button class="btn btn-secondary" onclick="document.getElementById('scroll-dialog').close()">Decline</button>
          <button class="btn btn-primary" onclick="document.getElementById('scroll-dialog').close()">Accept</button>
        </div>
      </dialog>
    </div>
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="dialog-stacked">
    <p class="text-xs font-semibold uppercase color-blue">Advanced</p>
    <h2>Stacked Dialogs</h2>

    <div class="border border-radius padding">
      <button class="btn btn-primary" onclick="document.getElementById('layer1-dialog').showModal()">Open Stacked Dialogs</button>
      <dialog id="layer1-dialog" class="dialog-layer-1" aria-labelledby="layer1-title">
        <div class="dialog-header">
          <h3 id="layer1-title">Layer 1 — Main Dialog</h3>
          <button class="dialog-close" onclick="document.getElementById('layer1-dialog').close()" aria-label="Close">&times;</button>
        </div>
        <div class="dialog-body">
          <p>Base dialog. Click below to open a nested dialog on top.</p>
          <button class="btn btn-primary btn-sm" onclick="document.getElementById('layer2-dialog').showModal()">Open Nested Dialog</button>
        </div>
        <div class="dialog-footer">
          <button class="btn btn-secondary" onclick="document.getElementById('layer1-dialog').close()">Close</button>
        </div>
      </dialog>
      <dialog id="layer2-dialog" class="dialog-layer-2 dialog-sm" aria-labelledby="layer2-title">
        <div class="dialog-header">
          <h3 id="layer2-title">Layer 2 — Nested</h3>
          <button class="dialog-close" onclick="document.getElementById('layer2-dialog').close()" aria-label="Close">&times;</button>
        </div>
        <div class="dialog-body"><p>This sits above the first dialog.</p></div>
        <div class="dialog-footer">
          <button class="btn btn-secondary" onclick="document.getElementById('layer2-dialog').close()">Close</button>
        </div>
      </dialog>
    </div>

    <CodeBlock code={`<dialog class="dialog-layer-1">...</dialog>
<dialog class="dialog-layer-2 dialog-sm">...</dialog>
<dialog class="dialog-layer-3">...</dialog>`} />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="alerts"
  >
    <p class="text-xs font-semibold uppercase color-blue">Alerts</p>
    <h2>Standard Alerts</h2>

    <div class="border border-radius padding">
      <div class="alert">
        <span class="alert-content">
          <strong>Default</strong> — A neutral notification message.
        </span>
      </div>
      <div class="alert alert-blue">
        <span class="alert-content">
          <strong>Information</strong> — Something you should know about.
        </span>
      </div>
      <div class="alert alert-green">
        <span class="alert-content">
          <strong>Success</strong> — Operation completed successfully.
        </span>
      </div>
      <div class="alert alert-yellow">
        <span class="alert-content">
          <strong>Warning</strong> — Proceed with caution.
        </span>
      </div>
      <div class="alert alert-red">
        <span class="alert-content">
          <strong>Error</strong> — Something went wrong.
        </span>
      </div>
      <div class="alert alert-black">
        <span class="alert-content">
          <strong>Neutral</strong> — A dark notification style.
        </span>
      </div>
    </div>

    <CodeBlock
      code={`<div class="alert alert-blue" role="status">
  <span class="alert-content">Info message here.</span>
</div>
<div class="alert alert-green" role="status">
  <span class="alert-content">Success!</span>
</div>
<div class="alert alert-red" role="alert">
  <span class="alert-content">Error occurred.</span>
</div>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="alert-outline"
  >
    <p class="text-xs font-semibold uppercase color-blue">Outline</p>
    <h2>Outlined Alerts</h2>
    <p>
      Tinted background with a full border using <code>alert-outline</code>.
    </p>

    <div class="border border-radius padding">
      <div class="alert alert-outline">
        <span class="alert-content">Default outlined alert.</span>
      </div>
      <div class="alert alert-blue alert-outline">
        <span class="alert-content">
          Outlined info alert with tinted background.
        </span>
      </div>
      <div class="alert alert-green alert-outline">
        <span class="alert-content">Outlined success alert.</span>
      </div>
      <div class="alert alert-yellow alert-outline">
        <span class="alert-content">Outlined warning alert.</span>
      </div>
      <div class="alert alert-red alert-outline">
        <span class="alert-content">Outlined error alert.</span>
      </div>
    </div>

    <CodeBlock
      code={`<div class="alert alert-blue alert-outline">
  <span class="alert-content">Outlined info alert.</span>
</div>`}
    />
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="alert-ghost"
  >
    <p class="text-xs font-semibold uppercase color-blue">Ghost</p>
    <h2>Ghost Alerts</h2>
    <p>
      Transparent background with border only using <code>alert-ghost</code>.
    </p>

    <div class="border border-radius padding">
      <div class="alert alert-blue alert-ghost">
        <span class="alert-content">
          Ghost info alert — transparent background.
        </span>
      </div>
      <div class="alert alert-green alert-ghost">
        <span class="alert-content">Ghost success alert.</span>
      </div>
      <div class="alert alert-red alert-ghost">
        <span class="alert-content">Ghost error alert.</span>
      </div>
    </div>
  </section>

  <section
    class="padding-top-extra padding-bottom-extra border-bottom"
    id="dismissible"
  >
    <p class="text-xs font-semibold uppercase color-blue">
      Interactive
    </p>
    <h2>Dismissible Alerts</h2>
    <p>
      Add an <code>alert-dismiss</code> button to make alerts closeable.
    </p>

    <button id="reset-btn" class="btn btn-sm btn-outline bottom-margin" style="display:none" onclick="document.querySelectorAll('#dismissible-alerts .alert').forEach(a=>a.style.display='');this.style.display='none'">Reset all dismissed alerts</button>

    <div id="dismissible-alerts" class="border border-radius padding">
      <div class="alert alert-blue" role="alert">
        <span class="alert-content">
          <strong>Tip:</strong> Click the × to dismiss this alert.
        </span>
        <button
          class="alert-dismiss"
          aria-label="Dismiss"
          onclick="this.closest('.alert').style.display='none'; document.getElementById('reset-btn').style.display=''"
        ></button>
      </div>
      <div class="alert alert-green" role="alert">
        <span class="alert-content">
          <strong>Saved!</strong> Your changes have been applied.
        </span>
        <button
          class="alert-dismiss"
          aria-label="Dismiss"
          onclick="this.closest('.alert').style.display='none'; document.getElementById('reset-btn').style.display=''"
        ></button>
      </div>
      <div class="alert alert-yellow alert-outline" role="alert">
        <span class="alert-content">
          <strong>Notice:</strong> Your session expires in 5 minutes.
        </span>
        <button
          class="alert-dismiss"
          aria-label="Dismiss"
          onclick="this.closest('.alert').style.display='none'; document.getElementById('reset-btn').style.display=''"
        ></button>
      </div>
      <div class="alert alert-red" role="alert">
        <span class="alert-content">
          <strong>Error:</strong> Failed to save. Please try again.
        </span>
        <button
          class="alert-dismiss"
          aria-label="Dismiss"
          onclick="this.closest('.alert').style.display='none'; document.getElementById('reset-btn').style.display=''"
        ></button>
      </div>
    </div>

    <CodeBlock
      code={`<div class="alert alert-blue" role="alert">
  <span class="alert-content">Dismissible alert.</span>
  <button class="btn btn-ghost btn-white btn-icon btn-xs" aria-label="Dismiss">&times;</button>
</div>`}
    />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="labels">
    <p class="text-xs font-semibold uppercase color-blue">Labels</p>
    <h2>Inline Labels & Status</h2>

    <div class="border border-radius padding bottom-margin">
      <span class="label">Default</span> <span class="label label-blue">Blue</span> <span class="label label-red">Red</span> <span class="label label-green">Green</span> <span class="label label-yellow">Yellow</span> <span class="label label-black">Black</span> <span class="label label-white">White</span>
    </div>

    <h3>Outlined Labels</h3>
    <div class="border border-radius padding bottom-margin">
      <span class="label label-outline">Outline</span> <span class="label label-outline label-blue">Blue</span> <span class="label label-outline label-red">Red</span> <span class="label label-outline label-green">Green</span>
    </div>

    <CodeBlock
      code={`<span class="label label-blue">Blue</span>
<span class="label label-outline">Outline</span>
<span class="label label-outline label-red">Red Outline</span>`}
    />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="badges">
    <p class="text-xs font-semibold uppercase color-blue">Badges</p>
    <h2>Badges</h2>

    <div class="border border-radius padding bottom-margin">
      <span class="badge">1</span> <span class="badge badge-blue">5</span> <span class="badge badge-red">99+</span> <span class="badge badge-green">3</span> <span class="badge badge-yellow">!</span> <span class="badge badge-black">0</span> <span class="badge badge-white">7</span>
    </div>

    <div class="border border-radius padding">
      <span class="badge badge-small badge-blue">sm</span> <span class="badge badge-small badge-red">sm</span> <span class="badge badge-small badge-green">sm</span>
    </div>

    <CodeBlock
      code={`<span class="badge badge-blue">5</span>
<span class="badge badge-red">99+</span>
<span class="badge badge-small badge-green">sm</span>`}
    />
  </section>

  <section class="padding-top-extra padding-bottom-extra border-bottom" id="messages">
    <p class="text-xs font-semibold uppercase color-blue">Toast</p>
    <h2>Toast Messages</h2>
    <p class="no-orphan">
      Fixed-position toast notifications using <code>tools-message</code> (alias: <code>message</code>).
      Hidden by default — toggle display with JavaScript.
    </p>

    <div class="border border-radius padding display-flex gap-sm flex-wrap">
      <button class="btn btn-sm" data-toast="toast-default">Default</button>
      <button class="btn btn-sm btn-blue" data-toast="toast-blue">Blue</button>
      <button class="btn btn-sm btn-green" data-toast="toast-green">Green</button>
      <button class="btn btn-sm btn-red" data-toast="toast-red">Red</button>
      <button class="btn btn-sm btn-yellow" data-toast="toast-yellow">Yellow</button>
    </div>

    <div id="toast-default" class="message" style="display:none" role="status" aria-live="polite">
      <span class="alert-content">Default toast notification.</span>
      <button class="btn btn-ghost btn-white btn-icon btn-xs" aria-label="Dismiss" onclick="this.parentElement.style.display='none';return false">&times;</button>
    </div>
    <div id="toast-blue" class="message message-blue" style="display:none" role="status" aria-live="polite">
      <span class="alert-content"><strong>Info:</strong> Something you should know.</span>
      <button class="btn btn-ghost btn-white btn-icon btn-xs" aria-label="Dismiss" onclick="this.parentElement.style.display='none';return false">&times;</button>
    </div>
    <div id="toast-green" class="message message-green" style="display:none" role="status" aria-live="polite">
      <span class="alert-content"><strong>Success:</strong> Changes saved.</span>
      <button class="btn btn-ghost btn-white btn-icon btn-xs" aria-label="Dismiss" onclick="this.parentElement.style.display='none';return false">&times;</button>
    </div>
    <div id="toast-red" class="message message-red" style="display:none" role="alert" aria-live="assertive">
      <span class="alert-content"><strong>Error:</strong> Something went wrong.</span>
      <button class="btn btn-ghost btn-white btn-icon btn-xs" aria-label="Dismiss" onclick="this.parentElement.style.display='none';return false">&times;</button>
    </div>
    <div id="toast-yellow" class="message message-yellow" style="display:none" role="status" aria-live="polite">
      <span class="alert-content"><strong>Warning:</strong> Check your input.</span>
      <button class="btn btn-ghost btn-black btn-icon btn-xs" aria-label="Dismiss" onclick="this.parentElement.style.display='none';return false">&times;</button>
    </div>

    <CodeBlock code={`<div class="message message-green" role="status" aria-live="polite">
  <span class="alert-content"><strong>Saved!</strong> Changes applied.</span>
  <button class="btn btn-ghost btn-white btn-icon btn-xs" aria-label="Dismiss">&times;</button>
</div>

<!-- For errors, use role="alert" and aria-live="assertive" -->
<div class="message message-red" role="alert" aria-live="assertive">
  <span class="alert-content">Error occurred.</span>
  <button class="btn btn-ghost btn-white btn-icon btn-xs" aria-label="Dismiss">&times;</button>
</div>`} />

    <h3>Accessibility</h3>
    <ul>
      <li>Use <code>role="status"</code> and <code>aria-live="polite"</code> for informational toasts — screen readers announce them after finishing the current task.</li>
      <li>Use <code>role="alert"</code> and <code>aria-live="assertive"</code> for errors — screen readers interrupt immediately.</li>
      <li>Always include a dismiss button with <code>aria-label="Dismiss"</code>.</li>
      <li>Toasts should auto-dismiss after a reasonable delay (5–10s), but not for error messages that require user action.</li>
    </ul>

    <table class="table-stroked">
      <tbody>
        <tr><td><code>message</code></td><td>Base toast (fixed top-right)</td></tr>
        <tr><td><code>message-blue</code></td><td>Blue toast</td></tr>
        <tr><td><code>message-red</code></td><td>Red toast</td></tr>
        <tr><td><code>message-green</code></td><td>Green toast</td></tr>
        <tr><td><code>message-yellow</code></td><td>Yellow toast</td></tr>
        <tr><td><code>message-black</code></td><td>Black toast</td></tr>
      </tbody>
    </table>
  </section>

  <section class="padding-top-extra padding-bottom-extra" id="alert-reference">
    <p class="text-xs font-semibold uppercase color-blue">Reference</p>
    <h2>Alert Class Reference</h2>
    <p class="no-orphan">
      All alert classes use the <code>tools-alert-*</code> prefix with shorter <code>alert-*</code> aliases.
    </p>

    <table class="table-stroked">
      <tbody>
        <tr><td><code>tools-alert</code> / <code>alert</code></td><td>Base alert</td></tr>
        <tr><td><code>tools-alert-blue</code> / <code>alert-blue</code></td><td>Blue/info</td></tr>
        <tr><td><code>tools-alert-red</code> / <code>alert-red</code></td><td>Red/error</td></tr>
        <tr><td><code>tools-alert-green</code> / <code>alert-green</code></td><td>Green/success</td></tr>
        <tr><td><code>tools-alert-yellow</code> / <code>alert-yellow</code></td><td>Yellow/warning</td></tr>
        <tr><td><code>tools-alert-black</code> / <code>alert-black</code></td><td>Black/neutral</td></tr>
        <tr><td><code>tools-alert-outline</code> / <code>alert-outline</code></td><td>Outlined variant</td></tr>
        <tr><td><code>tools-alert-ghost</code> / <code>alert-ghost</code></td><td>Ghost variant</td></tr>
        <tr><td><code>tools-alert-icon</code> / <code>alert-icon</code></td><td>Icon container</td></tr>
        <tr><td><code>tools-alert-content</code> / <code>alert-content</code></td><td>Content wrapper</td></tr>
        <tr><td><code>tools-alert-dismiss</code> / <code>alert-dismiss</code></td><td>Dismiss button</td></tr>
      </tbody>
    </table>
  </section>

  <section
    class="padding-top-extra padding-bottom-extra"
    id="next-steps"
  >
    <p class="text-xs font-semibold uppercase color-blue">Next</p>
    <h2>Next Steps</h2>
    <p class="text-secondary no-orphan">
      Explore <a href="/docs/utilities">utility classes</a> for
      spacing, display, and layout helpers, or learn about built-in <a href="/docs/accessibility">accessibility</a> features.
    </p>
  </section>

  <script>
    document.querySelectorAll('[data-toast]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.message').forEach(m => {
          (m as HTMLElement).style.display = 'none';
        });
        const toast = document.getElementById((btn as HTMLElement).dataset.toast!);
        if (toast) {
          toast.style.display = 'block';
          setTimeout(() => { toast.style.display = 'none'; }, 5000);
        }
      });
    });
  </script>
</DocsLayout>
